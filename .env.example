# ============================================
# MyGuru AI — Environment Variables Template
# Copy this file to .env and fill in values
# NEVER commit .env to GitHub!
# ============================================

# ── SUPABASE ──
# Get from: supabase.com → your project → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key-here
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ── ANTHROPIC (Claude AI) ──
# Get from: console.anthropic.com → API Keys
# Deposit $5 to get Tier 1 access (50 RPM)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── RAZORPAY ──
# Get from: dashboard.razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID=rzp_test_your-key-here
RAZORPAY_KEY_SECRET=your-secret-here
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret-here
# Note: Change rzp_test_ to rzp_live_ when going live

# ── RESEND (Email) ──
# Get from: resend.com → API Keys → Create API Key
RESEND_API_KEY=re_your-key-here

# ── OPENAI (for semantic cache embeddings) ──
# Get from: platform.openai.com → API Keys
# Only used for L3 cache — very cheap (₹0.001 per call)
OPENAI_API_KEY=sk-your-key-here

# ── APP CONFIG ──
PORT=3000
NODE_ENV=development
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5500

# ── PRODUCTION VALUES (update before going live) ──
# NODE_ENV=production
# APP_URL=https://api.myguruai.in
# FRONTEND_URL=https://myguruai.in
